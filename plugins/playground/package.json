{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-playground",
  "knip": {
    "entry": ["src/blocks/**/*.{ts,tsx}", "src/pages/**/*.{ts,tsx}"],
    "ignoreDependencies": ["lucide-react", "react"]
  },
  "displayName": "Playground",
  "version": "0.4.0",
  "private": true,
  "description": "Experimental sandbox plugin — echo block, preferences showcase, and a file browser demo",
  "author": "BRIKA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "plugins/playground"
  },
  "keywords": ["brika", "brika-plugin", "example", "demo", "kitchen-sink", "playground"],
  "engines": {
    "brika": "^0.4.0"
  },
  "grants": {
    "dev.brika.fs.readFile": {
      "read": ["/data/**"],
      "write": []
    },
    "dev.brika.fs.writeFile": {
      "read": [],
      "write": ["/data/**"]
    },
    "dev.brika.fs.readdir": {
      "read": ["/data/**"],
      "write": []
    },
    "dev.brika.fs.stat": {
      "read": ["/data/**"],
      "write": []
    },
    "dev.brika.fs.mkdir": {
      "read": [],
      "write": ["/data/**"]
    },
    "dev.brika.fs.rm": {
      "read": [],
      "write": ["/data/**"]
    }
  },
  "resources": {
    "fs": {
      "maxFileBytes": "512mb",
      "quotas": {
        "data": "5gb",
        "cache": "1gb",
        "tmp": "256mb"
      }
    }
  },
  "type": "module",
  "main": "./src/index.ts",
  "readme": { "en": "README.md", "fr": "README.fr.md" },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "locales", "README.md"],
  "scripts": {
    "dev": "brika dev",
    "build": "brika build",
    "typecheck": "brika check --types",
    "check": "brika check",
    "prepublishOnly": "brika verify"
  },
  "tools": [],
  "blocks": [
    {
      "id": "echo",
      "name": "Echo",
      "description": "Pass input through to output, optionally adding a prefix/suffix to string payloads",
      "category": "transform",
      "icon": "megaphone",
      "color": "#6366f1",
      "view": true,
      "nodeView": true,
      "fields": ["prefix", "suffix"]
    }
  ],
  "sparks": [
    {
      "id": "echoed"
    }
  ],
  "pages": [
    {
      "id": "file-browser"
    }
  ],
  "actions": [
    {
      "id": "2789a77e2eea",
      "file": "src/pages/file-browser/actions.ts",
      "name": "writeEntry"
    },
    {
      "id": "6c8bb95f5e90",
      "file": "src/pages/file-browser/actions.ts",
      "name": "makeFolder"
    },
    {
      "id": "7a42d22e7002",
      "file": "src/pages/file-browser/actions.ts",
      "name": "readEntry"
    },
    {
      "id": "bf18f3f337ec",
      "file": "src/pages/file-browser/actions.ts",
      "name": "listEntries"
    },
    {
      "id": "e73eb4f0eb95",
      "file": "src/pages/file-browser/actions.ts",
      "name": "deleteEntry"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "type": "password",
      "label": "API Key",
      "description": "Demo password field — value is stored in the OS keychain"
    },
    {
      "name": "serverUrl",
      "type": "text",
      "label": "Server URL",
      "description": "The base URL of the API server",
      "default": "https://api.example.com"
    },
    {
      "name": "maxRetries",
      "type": "number",
      "label": "Max Retries",
      "description": "Maximum number of retry attempts (1-10)",
      "default": 3,
      "min": 1,
      "max": 10
    },
    {
      "name": "debugMode",
      "type": "checkbox",
      "label": "Debug Mode",
      "description": "Enable verbose logging for troubleshooting",
      "default": false
    },
    {
      "name": "logLevel",
      "type": "dropdown",
      "label": "Log Level",
      "description": "Minimum log level to display",
      "default": "info",
      "options": [
        {
          "value": "debug"
        },
        {
          "value": "info"
        },
        {
          "value": "warn"
        },
        {
          "value": "error"
        }
      ]
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*"
  }
}
