{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-spotify",
  "displayName": "Spotify",
  "version": "0.3.1",
  "description": "Spotify Connect player for BRIKA dashboards",
  "author": "BRIKA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "plugins/spotify"
  },
  "icon": "./icon.svg",
  "keywords": [
    "brika",
    "brika-plugin",
    "spotify",
    "music",
    "player"
  ],
  "type": "module",
  "main": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "engines": {
    "brika": "^0.3.0"
  },
  "scripts": {
    "link": "bun link",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "brika-verify-plugin"
  },
  "preferences": [
    {
      "name": "clientId",
      "type": "text",
      "label": "Client ID",
      "description": "Spotify Developer App client ID",
      "required": true
    },
    {
      "name": "connect",
      "type": "link",
      "label": "Connect to Spotify",
      "description": "Authorize BRIKA to access your Spotify account",
      "url": "/api/oauth/spotify/authorize"
    },
    {
      "name": "developer",
      "type": "link",
      "label": "Spotify Developer Portal",
      "description": "Create and manage your Spotify app credentials",
      "url": "https://developer.spotify.com"
    },
    {
      "name": "defaultDevice",
      "type": "dynamic-dropdown",
      "label": "Default Device",
      "description": "Device to auto-start playback on"
    }
  ],
  "bricks": [
    {
      "id": "player",
      "name": "Spotify Player",
      "description": "Control Spotify playback and display album art",
      "category": "media",
      "icon": "music",
      "color": "#1DB954",
      "config": [
        {
          "type": "dynamic-dropdown",
          "name": "device",
          "label": "Device",
          "description": "Override the default device for this brick"
        },
        {
          "type": "number",
          "name": "refreshInterval",
          "label": "Refresh interval (ms)",
          "default": 3000,
          "min": 1000,
          "max": 30000,
          "step": 1000
        }
      ]
    }
  ],
  "blocks": [
    {
      "id": "play",
      "name": "Play Spotify",
      "description": "Start playback on a Spotify device",
      "category": "action",
      "icon": "play",
      "color": "#1DB954"
    }
  ],
  "sparks": [
    {
      "id": "track-changed",
      "name": "Track Changed",
      "description": "Emitted when the playing track changes"
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*"
  },
  "devDependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  },
  "files": [
    "src",
    "locales",
    "icon.svg",
    "README.md"
  ]
}
