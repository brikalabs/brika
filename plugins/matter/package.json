{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-matter",
  "displayName": "Brika Matter",
  "version": "0.4.0",
  "description": "Matter smart home device integration for BRIKA",
  "author": "BRIKA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "plugins/matter"
  },
  "icon": "./icon.svg",
  "keywords": ["brika", "brika-plugin", "matter", "smart-home", "iot", "light", "switch"],
  "engines": {
    "brika": "^0.4.0"
  },
  "grants": {
    "dev.brika.net.socket": {}
  },
  "type": "module",
  "main": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "dev": "brika dev",
    "build": "brika build",
    "typecheck": "brika check --types",
    "check": "brika check",
    "prepublishOnly": "brika verify"
  },
  "sparks": [
    {
      "id": "device-state-changed",
      "name": "Device State Changed",
      "description": "Emitted when any Matter device changes state"
    },
    {
      "id": "device-discovered",
      "name": "Device Discovered",
      "description": "Emitted when a new Matter device is found on the network"
    },
    {
      "id": "device-online",
      "name": "Device Online",
      "description": "Emitted when a device connects"
    },
    {
      "id": "device-offline",
      "name": "Device Offline",
      "description": "Emitted when a device disconnects"
    },
    {
      "id": "attribute-changed",
      "name": "Attribute Changed",
      "description": "Emitted for each device attribute that changes"
    }
  ],
  "blocks": [
    {
      "id": "command",
      "name": "Matter Command",
      "description": "Send a command to a Matter device (on/off, level, color)",
      "category": "action",
      "icon": "cpu",
      "color": "#6366f1",
      "view": true,
      "nodeView": true
    },
    {
      "id": "device-event",
      "name": "When Device Changes",
      "description": "Fires when a Matter device's attributes change or it emits an event (button press)",
      "category": "trigger",
      "icon": "radio",
      "color": "#6366f1",
      "view": true,
      "nodeView": true
    },
    {
      "id": "button-press",
      "name": "When Button Pressed",
      "description": "Fires once per button gesture (short, long, double or triple press) on a Matter switch or remote",
      "category": "trigger",
      "icon": "mouse-pointer-click",
      "color": "#6366f1"
    }
  ],
  "pages": [
    {
      "id": "devices",
      "icon": "cpu"
    }
  ],
  "bricks": [
    {
      "id": "devices",
      "name": "Matter Devices",
      "description": "View and manage Matter devices on your network",
      "category": "monitoring",
      "icon": "cpu",
      "color": "#6366f1"
    },
    {
      "id": "device",
      "name": "Matter Device",
      "description": "Control any Matter device, adapting to lights, locks, covers, thermostats and more",
      "category": "control",
      "icon": "cpu",
      "color": "#6366f1",
      "config": [
        {
          "type": "dynamic-dropdown",
          "name": "deviceId",
          "label": "Device",
          "description": "Select a commissioned Matter device"
        }
      ]
    },
    {
      "id": "commission",
      "name": "Add a Matter Device",
      "description": "Pair a new Matter device from a dashboard with its setup code",
      "category": "control",
      "icon": "plus",
      "color": "#6366f1"
    }
  ],
  "preferences": [
    {
      "name": "autoCommission",
      "type": "checkbox",
      "label": "Auto-commission",
      "description": "Automatically commission discovered devices",
      "default": false
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*",
    "@matter/main": "^0.17.1",
    "@matter/nodejs": "^0.17.1",
    "@project-chip/matter.js": "^0.17.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  },
  "files": ["src", "locales", "icon.svg", "README.md"]
}
