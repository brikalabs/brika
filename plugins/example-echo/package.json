{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-example-echo",
  "version": "0.2.1",
  "description": "Example echo plugin demonstrating reactive blocks",
  "author": "BRIKA Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/brika.git",
    "directory": "plugins/example-echo"
  },
  "keywords": [
    "example",
    "echo",
    "demo"
  ],
  "engines": {
    "brika": "^0.2.0"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "link": "bun link",
    "tsc": "bunx --bun tsc --noEmit"
  },
  "blocks": [
    {
      "id": "echo",
      "name": "Echo",
      "description": "Echoes input to output with optional prefix/suffix",
      "category": "transform",
      "icon": "message-circle",
      "color": "#3b82f6"
    }
  ],
  "sparks": [
    {
      "id": "echoed",
      "name": "Message Echoed",
      "description": "Emitted when a message is echoed"
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*"
  }
}
