{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-demo-config",
  "displayName": "Config Demo",
  "version": "0.3.1",
  "private": true,
  "description": "Demo plugin showcasing the preferences system",
  "author": "BRIKA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "plugins/demo-config"
  },
  "keywords": ["brika", "brika-plugin", "demo", "config", "preferences"],
  "engines": {
    "brika": "^0.3.0"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "link": "bun link",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "brika-verify-plugin"
  },
  "grants": {},
  "preferences": [
    {
      "name": "apiKey",
      "type": "password",
      "label": "API Key",
      "description": "Your secret API key for authentication",
      "required": true
    },
    {
      "name": "serverUrl",
      "type": "text",
      "label": "Server URL",
      "description": "The base URL of the API server",
      "default": "https://api.example.com"
    },
    {
      "name": "maxRetries",
      "type": "number",
      "label": "Max Retries",
      "description": "Maximum number of retry attempts (1-10)",
      "default": 3,
      "min": 1,
      "max": 10
    },
    {
      "name": "debugMode",
      "type": "checkbox",
      "label": "Debug Mode",
      "description": "Enable verbose logging for troubleshooting",
      "default": false
    },
    {
      "name": "logLevel",
      "type": "dropdown",
      "label": "Log Level",
      "description": "Minimum log level to display",
      "default": "info",
      "options": [
        { "value": "debug" },
        { "value": "info" },
        { "value": "warn" },
        { "value": "error" }
      ]
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*"
  }
}
