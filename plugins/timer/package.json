{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-timer",
  "version": "0.1.1",
  "description": "Timer and reminder functionality for BRIKA",
  "author": "BRIKA Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/brika.git",
    "directory": "plugins/timer"
  },
  "icon": "./icon.svg",
  "keywords": [
    "timer",
    "reminder",
    "delay",
    "countdown"
  ],
  "engines": {
    "brika": "^0.1.1"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "link": "bun link"
  },
  "tools": [
    {
      "id": "set",
      "description": "Set a timer that fires after the specified duration",
      "icon": "timer",
      "color": "#22c55e"
    },
    {
      "id": "list",
      "description": "List all active timers with remaining time",
      "icon": "list",
      "color": "#3b82f6"
    },
    {
      "id": "cancel",
      "description": "Cancel an active timer by ID or name",
      "icon": "x-circle",
      "color": "#ef4444"
    },
    {
      "id": "clear",
      "description": "Clear all active timers at once",
      "icon": "trash-2",
      "color": "#f97316"
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.5"
  }
}
