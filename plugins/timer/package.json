{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "@brika/plugin-timer",
  "displayName": "Timer",
  "version": "0.3.0",
  "description": "Timer and countdown blocks for BRIKA workflows",
  "author": "BRIKA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/brika.git",
    "directory": "plugins/timer"
  },
  "icon": "./icon.svg",
  "keywords": [
    "brika",
    "brika-plugin",
    "timer",
    "countdown",
    "delay"
  ],
  "engines": {
    "brika": "^0.3.0"
  },
  "type": "module",
  "main": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "link": "bun link",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "brika-verify-plugin"
  },
  "blocks": [
    {
      "id": "timer",
      "name": "Timer",
      "description": "Set a one-shot timer that fires after a duration",
      "category": "trigger",
      "icon": "timer",
      "color": "#22c55e"
    },
    {
      "id": "countdown",
      "name": "Countdown",
      "description": "Countdown with progress ticks",
      "category": "trigger",
      "icon": "clock",
      "color": "#3b82f6"
    }
  ],
  "bricks": [
    {
      "id": "timers-dashboard",
      "name": "Timers Dashboard",
      "description": "Overview of active timers and countdowns",
      "category": "monitoring",
      "icon": "timer",
      "color": "#22c55e",
      "config": [
        {
          "type": "number",
          "name": "refreshInterval",
          "label": "Refresh Interval (ms)",
          "description": "How often to update uptime",
          "default": 5000,
          "min": 1000,
          "max": 30000,
          "step": 1000
        }
      ]
    },
    {
      "id": "photo",
      "name": "Photo",
      "description": "Photo showcase with auto-rotation",
      "category": "media",
      "icon": "image",
      "color": "#8b5cf6",
      "config": [
        {
          "type": "checkbox",
          "name": "autoRotate",
          "label": "Auto-rotate",
          "description": "Automatically cycle through photos",
          "default": true
        },
        {
          "type": "number",
          "name": "interval",
          "label": "Interval (ms)",
          "description": "Time between photo changes",
          "default": 8000,
          "min": 1000,
          "max": 60000,
          "step": 1000
        }
      ]
    },
    {
      "id": "camera",
      "name": "Live Video",
      "description": "HLS video stream with controls",
      "category": "media",
      "icon": "video",
      "color": "#ef4444",
      "config": [
        {
          "type": "dropdown",
          "name": "defaultStream",
          "label": "Default Stream",
          "options": [
            {
              "value": "Big Buck Bunny"
            },
            {
              "value": "Elephants Dream"
            },
            {
              "value": "Sintel"
            }
          ],
          "default": "Big Buck Bunny"
        },
        {
          "type": "checkbox",
          "name": "muted",
          "label": "Muted by default",
          "description": "Start the stream muted",
          "default": true
        }
      ]
    }
  ],
  "sparks": [
    {
      "id": "timer-started",
      "name": "Timer Started",
      "description": "Emitted when a timer begins"
    },
    {
      "id": "timer-completed",
      "name": "Timer Completed",
      "description": "Emitted when a timer finishes"
    },
    {
      "id": "countdown-tick",
      "name": "Countdown Tick",
      "description": "Emitted on each countdown progress tick"
    },
    {
      "id": "countdown-completed",
      "name": "Countdown Completed",
      "description": "Emitted when a countdown finishes"
    }
  ],
  "dependencies": {
    "@brika/sdk": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  },
  "files": [
    "src",
    "locales",
    "icon.svg",
    "README.md"
  ]
}
