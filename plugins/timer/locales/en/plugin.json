{
  "name": "Timer Plugin",
  "description": "Timer and reminder functionality for BRIKA",
  "bricks": {
    "timers-dashboard": {
      "name": "Timers Dashboard",
      "description": "Overview of active timers and countdowns",
      "config": {
        "refreshInterval": {
          "label": "Refresh Interval (ms)",
          "description": "How often to update uptime"
        }
      }
    },
    "photo": {
      "name": "Photo",
      "description": "Photo showcase with auto-rotation",
      "config": {
        "autoRotate": {
          "label": "Auto-rotate",
          "description": "Automatically cycle through photos"
        },
        "interval": {
          "label": "Interval (ms)",
          "description": "Time between photo changes"
        }
      }
    },
    "camera": {
      "name": "Live Video",
      "description": "HLS video stream with controls",
      "config": {
        "defaultStream": {
          "label": "Default Stream",
          "options": {
            "Big Buck Bunny": "Big Buck Bunny",
            "Elephants Dream": "Elephants Dream",
            "Sintel": "Sintel"
          }
        },
        "muted": {
          "label": "Muted by default",
          "description": "Start the stream muted"
        }
      }
    }
  },
  "blocks": {
    "timer": {
      "name": "Timer",
      "description": "Set a one-shot timer that fires after a duration"
    },
    "countdown": {
      "name": "Countdown",
      "description": "Countdown with progress ticks"
    }
  },
  "fields": {
    "name": {
      "label": "Name",
      "description": "Timer name",
      "placeholder": "timer"
    }
  },
  "sparks": {
    "timer-started": {
      "name": "Timer Started",
      "description": "Emitted when a timer begins"
    },
    "timer-completed": {
      "name": "Timer Completed",
      "description": "Emitted when a timer finishes"
    },
    "countdown-tick": {
      "name": "Countdown Tick",
      "description": "Emitted on each countdown progress tick"
    },
    "countdown-completed": {
      "name": "Countdown Completed",
      "description": "Emitted when a countdown finishes"
    }
  }
}
