{
  "name": "Timer Plugin",
  "description": "Timer and reminder functionality for BRIKA",
  "tools": {
    "set": {
      "name": "Set Timer",
      "description": "Set a timer that fires after the specified duration"
    },
    "list": {
      "name": "List Timers",
      "description": "List all active timers with remaining time"
    },
    "cancel": {
      "name": "Cancel Timer",
      "description": "Cancel an active timer by ID or name"
    },
    "clear": {
      "name": "Clear All",
      "description": "Clear all active timers at once"
    }
  },
  "bricks": {
    "timers-dashboard": {
      "name": "Timers Dashboard",
      "description": "Overview of active timers and countdowns",
      "config": {
        "refreshInterval": {
          "label": "Refresh Interval (ms)",
          "description": "How often to update uptime"
        }
      }
    },
    "photo": {
      "name": "Photo",
      "description": "Photo showcase with auto-rotation",
      "config": {
        "autoRotate": {
          "label": "Auto-rotate",
          "description": "Automatically cycle through photos"
        },
        "interval": {
          "label": "Interval (ms)",
          "description": "Time between photo changes"
        }
      }
    },
    "camera": {
      "name": "Live Video",
      "description": "HLS video stream with controls",
      "config": {
        "defaultStream": {
          "label": "Default Stream",
          "options": {
            "Big Buck Bunny": "Big Buck Bunny",
            "Elephants Dream": "Elephants Dream",
            "Sintel": "Sintel"
          }
        },
        "muted": {
          "label": "Muted by default",
          "description": "Start the stream muted"
        }
      }
    }
  },
  "events": {
    "completed": "Timer completed",
    "cancelled": "Timer cancelled"
  },
  "fields": {
    "name": {
      "label": "Name",
      "description": "Timer name"
    },
    "seconds": {
      "label": "Seconds",
      "description": "Duration in seconds"
    },
    "target": {
      "label": "Target",
      "description": "Timer ID or name to cancel"
    }
  },
  "sparks": {
    "timer-started": {
      "name": "Timer Started",
      "description": "Emitted when a timer begins"
    },
    "timer-completed": {
      "name": "Timer Completed",
      "description": "Emitted when a timer finishes"
    },
    "countdown-tick": {
      "name": "Countdown Tick",
      "description": "Emitted on each countdown progress tick"
    },
    "countdown-completed": {
      "name": "Countdown Completed",
      "description": "Emitted when a countdown finishes"
    }
  }
}
