{
  "name": "brika",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git"
  },
  "homepage": "https://github.com/brikalabs/brika",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "workspaces": ["apps/*", "packages/*", "plugins/*"],
  "scripts": {
    "dev": "BRIKA_DEV_UI_PROXY=http://localhost:5173 bun --filter @brika/hub --filter @brika/ui dev",
    "dev:hub": "bun --filter @brika/hub dev",
    "dev:hub:proxied": "BRIKA_DEV_UI_PROXY=http://localhost:5173 bun --filter @brika/hub dev",
    "dev:ui": "bun --filter @brika/ui dev",
    "dev:worker": "bun --filter @brika/signaling-worker dev",
    "dev:bootstrap": "bun --filter @brika/signaling-bootstrap --filter @brika/signaling-worker dev",
    "dev:remote": "BRIKA_COORDINATOR_URL=http://localhost:8787 BRIKA_DEV_UI_PROXY=http://localhost:5173 BRIKA_DEV_AUTOCLAIM=devhub bun --filter @brika/signaling-worker --filter @brika/ui --filter @brika/hub dev",
    "test": "bun --filter '*' test --parallel",
    "test:coverage": "bun --filter '*' test --parallel",
    "typecheck": "bun --filter '*' typecheck",
    "build": "bun run --filter './packages/*' build",
    "compile": "bun run --filter @brika/ui build && bun run --filter @brika/hub build --compile",
    "lint": "bunx biome check .",
    "lint:strict": "bunx biome check . --error-on-warnings",
    "lint:fix": "bunx biome check --write .",
    "i18n:types": "bun --filter @brika/i18n-devtools generate-types",
    "i18n:check": "bun --filter @brika/i18n-devtools check",
    "bump": "bump-version",
    "publish-packages": "publish-packages",
    "local-install": "local-install"
  },
  "engines": {
    "bun": "1.3.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@brika/hub": "workspace:*",
    "@brika/i18n-devtools": "workspace:*",
    "@brika/testing": "workspace:*",
    "@brika/workspace-tools": "workspace:*",
    "@typescript/native-preview": "7.0.0-dev.20260412.1",
    "bun-types": "^1.3.13",
    "mitata": "^1.0.34",
    "typescript": "^6.0.2"
  }
}
