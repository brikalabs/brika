{
  "name": "brika",
  "knip": {
    "ignoreDependencies": ["@brika/hub", "@brika/i18n-devtools", "@brika/sdk", "@brika/testing"]
  },
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git"
  },
  "homepage": "https://github.com/brikalabs/brika",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "workspaces": ["apps/*", "packages/*", "plugins/*"],
  "scripts": {
    "dev": "BRIKA_COORDINATOR_URL=http://localhost:5174 BRIKA_DEV_UI_PROXY=http://localhost:5173 BRIKA_DEV_AUTOCLAIM=devhub bun --filter @brika/signaling --filter @brika/ui --filter @brika/hub dev",
    "dev:hub": "bun --filter @brika/hub dev",
    "dev:hub:proxied": "BRIKA_DEV_UI_PROXY=http://localhost:5173 bun --filter @brika/hub dev",
    "dev:ui": "bun --filter @brika/ui dev",
    "dev:signaling": "bun --filter @brika/signaling dev",
    "up": "mortar",
    "brika": "bun apps/console/src/main.ts",
    "test": "bun --filter '*' --parallel test --timeout=30000",
    "test:coverage": "bun --filter '*' --parallel test --timeout=30000",
    "typecheck": "bun run --filter @brika/sdk build:bin && bun --filter '*' --parallel typecheck",
    "build": "bun run --filter './packages/*' build",
    "compile": "bun run --filter @brika/ui build && bun run --filter @brika/build build --compile",
    "compile:headless": "bun run --filter @brika/build build --compile --target=headless",
    "docker:build": "bun packages/workspace-tools/src/docker-build.ts",
    "lint": "bunx biome check .",
    "lint:strict": "bunx biome check . --error-on-warnings",
    "lint:fix": "bunx biome check --write .",
    "i18n:types": "bun packages/i18n-dev/src/generate-types.ts --locales apps/hub/src/locales/en",
    "i18n:check": "bun packages/i18n-dev/src/check.ts --locales apps/hub/src/locales",
    "bump": "bump-version",
    "publish-packages": "publish-packages",
    "local-install": "local-install",
    "deadcode": "bun run --filter @brika/workspace-tools deadcode",
    "changeset": "changeset",
    "version-packages": "changeset version && bun run sync:engines-brika && bun install --lockfile-only",
    "release": "bun run packages/workspace-tools/src/release-libs.ts",
    "sync:engines-brika": "bun run packages/workspace-tools/src/sync-engines-brika.ts"
  },
  "engines": {
    "bun": "^1.3.14"
  },
  "overrides": {
    "ip": "npm:neoip@^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@brika/hub": "workspace:*",
    "@brika/sdk": "workspace:*",
    "@brika/i18n-devtools": "workspace:*",
    "@brika/mortar": "workspace:*",
    "@brika/testing": "workspace:*",
    "@brika/workspace-tools": "workspace:*",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.12",
    "@typescript/native-preview": "^7.0.0-dev.20260608.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3",
    "zod": "^4.3.4"
  }
}
