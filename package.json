{
  "name": "brika",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/brika.git"
  },
  "homepage": "https://github.com/maxscharwath/brika",
  "bugs": {
    "url": "https://github.com/maxscharwath/brika/issues"
  },
  "workspaces": ["apps/*", "packages/*", "plugins/*"],
  "scripts": {
    "dev": "bun --filter @brika/hub --filter @brika/ui dev",
    "dev:hub": "bun --filter @brika/hub dev",
    "dev:ui": "bun --filter @brika/ui dev",
    "test": "bun test",
    "tsc": "bun --filter '*' tsc",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "bun-types": "^1.3.5",
    "typescript": "^5.9.3"
  }
}
