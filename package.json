{
  "name": "elia",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/elia.git"
  },
  "homepage": "https://github.com/maxscharwath/elia",
  "bugs": {
    "url": "https://github.com/maxscharwath/elia/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "bun run dev:hub & bun run dev:ui",
    "dev:hub": "cd apps/hub && bun run src/main.ts",
    "dev:ui": "cd apps/ui && bunx --bun vite",
    "build": "cd apps/ui && bunx --bun vite build",
    "test": "bun test",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10"
  }
}
