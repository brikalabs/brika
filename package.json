{
  "name": "brika",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/brika.git"
  },
  "homepage": "https://github.com/maxscharwath/brika",
  "bugs": {
    "url": "https://github.com/maxscharwath/brika/issues"
  },
  "workspaces": ["apps/*", "packages/*", "plugins/*"],
  "scripts": {
    "dev": "bun --filter @brika/hub --filter @brika/ui dev",
    "dev:hub": "bun --filter @brika/hub dev",
    "dev:ui": "bun --filter @brika/ui dev",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "tsc": "bun --filter '*' tsc",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "postinstall": "bun link:bins",
    "link:bins": "ln -sf ../../packages/arch/src/cli.ts node_modules/.bin/brika-arch 2>/dev/null; ln -sf ../../../../packages/arch/src/cli.ts apps/ui/node_modules/.bin/brika-arch 2>/dev/null || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
