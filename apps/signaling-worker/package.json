{
  "name": "@brika/signaling-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Brika signaling coordinator on Cloudflare Workers (DO + D1)",
  "scripts": {
    "dev": "bun --filter @brika/signaling-bootstrap build && wrangler dev",
    "deploy": "bun --filter @brika/signaling-bootstrap build && wrangler deploy",
    "tail": "wrangler tail",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply brika-signaling --local",
    "d1:migrate:prod": "wrangler d1 migrations apply brika-signaling --remote"
  },
  "dependencies": {
    "@brika/remote-access-protocol": "workspace:*",
    "hono": "^4.12.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "wrangler": "^4.0.0"
  }
}
