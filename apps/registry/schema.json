{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Brika Verified Plugins Registry",
  "description": "Schema for the verified plugins registry (v2 with signatures)",
  "type": "object",
  "required": [
    "version",
    "lastUpdated",
    "plugins"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the registry format"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "publicKey": {
      "type": "string",
      "description": "Base64-encoded raw Ed25519 public key (32 bytes)"
    },
    "signature": {
      "type": "string",
      "description": "Hex-encoded Ed25519 signature of the registry (128 chars)"
    },
    "plugins": {
      "type": "array",
      "description": "List of verified plugins",
      "items": {
        "type": "object",
        "required": [
          "name",
          "verifiedAt",
          "verifiedBy"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "npm package name"
          },
          "verifiedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of verification"
          },
          "verifiedBy": {
            "type": "string",
            "description": "Who verified this plugin (e.g., maintainer, community)"
          },
          "description": {
            "type": "string",
            "description": "Brief description of the plugin",
            "default": ""
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Searchable tags",
            "default": []
          },
          "minVersion": {
            "type": "string",
            "description": "Minimum Brika version required"
          },
          "featured": {
            "type": "boolean",
            "description": "Whether this plugin is featured",
            "default": false
          },
          "category": {
            "type": "string",
            "description": "Plugin category",
            "enum": [
              "official",
              "community",
              "utility",
              "integration",
              "workflow"
            ],
            "default": "community"
          },
          "source": {
            "type": "string",
            "description": "Where the package is hosted",
            "enum": [
              "npm",
              "github",
              "url"
            ],
            "default": "npm"
          },
          "signature": {
            "type": "string",
            "description": "Hex-encoded Ed25519 signature of this plugin entry (128 chars)"
          }
        }
      }
    }
  }
}
