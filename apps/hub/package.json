    "hono": "^4.12.22",
    "picocolors": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.3.0",
    "werift": "^0.23.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@brika/testing": "workspace:*",
    "@types/bun": "^1.3.14"
