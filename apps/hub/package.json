{
  "name": "@brika/hub",
  "knip": { "entry": ["src/runtime/plugins/prelude/**/*.ts"] },
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/brikalabs/brika",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "apps/hub"
  },
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "default": "./src/main.ts"
    },
    "./updater": "./src/runtime/updates/updater.ts",
    "./self-check": "./src/runtime/updates/self-check.ts",
    "./update-lock": "./src/runtime/updates/update-lock.ts",
    "./update-prefs": "./src/runtime/updates/update-prefs.ts",
    "./update-strategy": "./src/runtime/updates/update-strategy.ts",
    "./runtime-mode": "./src/runtime/updates/runtime-mode.ts",
    "./brika-context": "./src/runtime/context/brika-context.ts",
    "./uninstaller": "./src/runtime/uninstaller.ts"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "typecheck": "tsgo --project tsconfig.check.json --noEmit",
    "lint": "bun x biome check .",
    "test": "bun test --parallel",
    "lint:fix": "bun x biome check . --write"
  },
  "dependencies": {
    "@brika/analytics": "workspace:*",
    "@brika/auth": "workspace:*",
    "@brika/banner": "workspace:*",
    "@brika/compiler": "workspace:*",
    "@brika/db": "workspace:*",
    "@brika/di": "workspace:*",
    "@brika/errors": "workspace:*",
    "@brika/events": "workspace:*",
    "@brika/grants": "workspace:*",
    "@brika/http": "workspace:*",
    "@brika/i18n": "workspace:*",
    "@brika/ipc": "workspace:*",
    "@brika/permissions": "workspace:*",
    "@brika/plugin": "workspace:*",
    "@brika/registry": "workspace:*",
    "@brika/remote-access-protocol": "workspace:*",
    "@brika/router": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/sdk": "workspace:*",
    "@brika/type-system": "workspace:*",
    "@brika/ui-kit": "workspace:*",
    "date-fns": "^4.4.0",
    "hono": "^4.12.24",
    "picocolors": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.3.0",
    "werift": "^0.23.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@brika/testing": "workspace:*",
    "@types/bun": "^1.3.14"
  }
}
