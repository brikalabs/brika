    "test": "bun test",
    "lint:fix": "bun x biome check . --write"
  },
  "dependencies": {
    "@brika/auth": "workspace:*",
    "@brika/banner": "workspace:*",
    "@brika/compiler": "workspace:*",
    "@brika/db": "workspace:*",
    "@brika/di": "workspace:*",
    "@brika/errors": "workspace:*",
    "@brika/events": "workspace:*",
    "@brika/grants": "workspace:*",
    "@brika/http": "workspace:*",
    "@brika/i18n": "workspace:*",
    "@brika/ipc": "workspace:*",
    "@brika/permissions": "workspace:*",
    "@brika/plugin": "workspace:*",
    "@brika/registry": "workspace:*",
    "@brika/remote-access-protocol": "workspace:*",
    "@brika/router": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/sdk": "workspace:*",
    "@brika/type-system": "workspace:*",
    "@brika/ui-kit": "workspace:*",
    "@brika/workflow": "workspace:*",
