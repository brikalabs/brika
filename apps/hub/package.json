{
  "name": "@brika/hub",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/brikalabs/brika",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "apps/hub"
  },
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "default": "./src/main.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "typecheck": "tsgo --project tsconfig.check.json --noEmit",
