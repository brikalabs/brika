---
import MainLayout from '~/layouts/MainLayout.astro';
import { COMPONENT_GROUPS, COMPONENTS, componentsInGroup } from '~/lib/component-registry';
---

<MainLayout
  title="Components — Clay"
  description="Every Clay component in one place. Click through to full docs and live demos."
>
  <div class="mx-auto max-w-5xl px-6 py-10 md:px-10">
    <header class="mb-10">
      <p class="mb-2 font-medium font-mono text-clay-subtle text-xs uppercase tracking-wider">
        Components · {COMPONENTS.length}
      </p>
      <h1 class="font-semibold text-4xl text-clay-strong tracking-tighter md:text-5xl">
        Every Clay component
      </h1>
      <p class="mt-3 max-w-2xl text-clay-subtle text-lg leading-relaxed">
        {COMPONENTS.length} primitives, grouped by intent. Each page renders live demos against the active theme.
      </p>
    </header>

    {
      COMPONENT_GROUPS.map((group) => {
        const items = componentsInGroup(group);
        if (items.length === 0) return null;
        return (
          <section class="mb-12">
            <div class="mb-4 flex items-baseline justify-between border-clay-hairline border-b pb-2">
              <h2 class="font-semibold text-clay-strong text-lg tracking-tight">{group}</h2>
              <span class="font-mono text-clay-subtle text-xs">{items.length}</span>
            </div>
            <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-clay-hairline bg-clay-hairline sm:grid-cols-2 lg:grid-cols-3">
              {items.map((component) => (
                <a
                  href={`/components/${component.slug}`}
                  class="group flex flex-col gap-2 bg-clay-elevated p-4 transition-colors hover:bg-clay-base"
                >
                  <p class="font-medium text-clay-strong text-sm transition-colors group-hover:text-clay-strong">
                    {component.name}
                  </p>
                  <p class="line-clamp-2 text-clay-subtle text-xs leading-snug">
                    {component.description}
                  </p>
                </a>
              ))}
            </div>
          </section>
        );
      })
    }
  </div>
</MainLayout>
