---
import {
  ButtonIconDemo,
  ButtonOutlineDemo,
  ButtonPrimaryDemo,
} from '~/components/demos/button.tsx';
import { CardAccentDemo, CardDefaultDemo } from '~/components/demos/card.tsx';
import { InputDefaultDemo, InputInvalidDemo } from '~/components/demos/input.tsx';
import MainLayout from '~/layouts/MainLayout.astro';

const liveCount = 3;

const comingSoon = [
  'Label',
  'Badge',
  'Separator',
  'Dialog',
  'Tooltip',
  'Tabs',
  'Popover',
  'Select',
  'Switch',
  'Alert',
  'Progress',
  'Skeleton',
];
---

<MainLayout
  title="Components — Clay"
  description="Every Clay component in one place. Click through to full docs and live demos."
>
  <div class="mx-auto max-w-5xl px-6 py-10 md:px-10">
    <header class="mb-10">
      <p class="mb-2 font-medium font-mono text-clay-subtle text-xs uppercase tracking-wider">
        Components
      </p>
      <h1 class="font-semibold text-4xl text-clay-strong tracking-tighter md:text-5xl">
        Every Clay component
      </h1>
      <p class="mt-3 max-w-2xl text-clay-subtle text-lg leading-relaxed">
        Three primitives today; more land as the twinkly-wave migration
        continues. Click any card below for full docs, props, and live demos.
      </p>
    </header>

    <section class="mb-16">
      <div class="grid grid-cols-1 border-clay-hairline border-b sm:grid-cols-2 lg:grid-cols-3">
        <a
          href="/components/button"
          class="group flex min-h-[220px] flex-col border-clay-hairline border-t border-r transition-colors hover:bg-clay-base"
        >
          <div class="flex flex-1 items-center justify-center p-6">
            <div class="flex flex-col items-center gap-2">
              <ButtonPrimaryDemo client:load />
              <ButtonOutlineDemo client:load />
              <ButtonIconDemo client:load />
            </div>
          </div>
          <div class="border-clay-hairline border-t px-4 py-2">
            <p class="font-mono text-clay-default text-xs transition-colors group-hover:text-clay-strong">
              Button
            </p>
            <p class="text-clay-subtle text-xs">
              Primary action affordance with CVA variants.
            </p>
          </div>
        </a>

        <a
          href="/components/input"
          class="group flex min-h-[220px] flex-col border-clay-hairline border-t border-r transition-colors hover:bg-clay-base"
        >
          <div class="flex flex-1 items-center justify-center p-6">
            <div class="flex w-full max-w-[220px] flex-col gap-2">
              <InputDefaultDemo client:load />
              <InputInvalidDemo client:load />
            </div>
          </div>
          <div class="border-clay-hairline border-t px-4 py-2">
            <p class="font-mono text-clay-default text-xs transition-colors group-hover:text-clay-strong">
              Input
            </p>
            <p class="text-clay-subtle text-xs">
              Themed single-line text input.
            </p>
          </div>
        </a>

        <a
          href="/components/card"
          class="group flex min-h-[220px] flex-col border-clay-hairline border-t border-r transition-colors hover:bg-clay-base"
        >
          <div class="flex flex-1 items-center justify-center p-6">
            <div class="flex flex-col items-center gap-2">
              <CardDefaultDemo client:load />
              <CardAccentDemo client:load />
            </div>
          </div>
          <div class="border-clay-hairline border-t px-4 py-2">
            <p class="font-mono text-clay-default text-xs transition-colors group-hover:text-clay-strong">
              Card
            </p>
            <p class="text-clay-subtle text-xs">
              Surface container with accent + interactive variants.
            </p>
          </div>
        </a>

        {
          comingSoon.map((name) => (
            <div class="flex min-h-[220px] flex-col border-clay-hairline border-t border-r">
              <div class="flex flex-1 items-center justify-center p-6">
                <span class="font-mono text-clay-inactive text-xs uppercase tracking-wider">
                  coming soon
                </span>
              </div>
              <div class="border-clay-hairline border-t px-4 py-2">
                <p class="font-mono text-clay-inactive text-xs">{name}</p>
                <p class="text-clay-inactive text-xs">Pipeline — migrating from apps/ui.</p>
              </div>
            </div>
          ))
        }
      </div>

      <p class="mt-6 font-mono text-clay-subtle text-xs">
        {liveCount} live · {comingSoon.length} on deck
      </p>
    </section>
  </div>
</MainLayout>
