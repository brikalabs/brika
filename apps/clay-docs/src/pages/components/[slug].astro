---
import { DemoRenderer } from '~/components/DemoRenderer.tsx';
import { CodeSource } from '~/components/docs/CodeSource.tsx';
import ComponentExample from '~/components/docs/ComponentExample.astro';
import MdxDocLayout from '~/layouts/MdxDocLayout.astro';
import { adjacentComponents, COMPONENTS, type ComponentEntry } from '~/lib/component-registry';

interface Props {
  readonly component: ComponentEntry;
}

export function getStaticPaths() {
  return COMPONENTS.map((component) => ({
    params: { slug: component.slug },
    props: { component },
  }));
}

const { component } = Astro.props;
const { previous, next } = adjacentComponents(component.slug);

const barrelImport = `import { ${component.name} } from "@brika/clay";`;
const granularImport = `import { ${component.name} } from "@brika/clay/components/${component.slug}";`;

const [heroDemo, ...moreDemos] = component.demos;

function slugifyTitle(title: string): string {
  return title.toLowerCase().replace(/\s+/g, '-');
}

const githubBase = `https://github.com/brikalabs/brika/tree/main/packages/clay/src/components/${component.slug}`;

const headingClass = 'mb-3 scroll-mt-24 font-semibold text-2xl text-clay-strong tracking-tight';
const subHeadingClass = 'mb-2 scroll-mt-24 font-medium text-clay-strong text-lg tracking-tight';
---

<MdxDocLayout
  frontmatter={{
    title: component.name,
    description: component.description,
    sourceFile: `components/${component.slug}`,
  }}
>
  <p class="mb-10 inline-flex items-center gap-2 font-medium font-mono text-clay-subtle text-xs uppercase tracking-wider">
    {component.group}
  </p>

  {
    heroDemo && (
      <section class="mb-14">
        <ComponentExample code={heroDemo.code}>
          <DemoRenderer slug={component.slug} demoName={heroDemo.name} client:only="react" />
        </ComponentExample>
      </section>
    )
  }

  <section class="mb-14">
    <h2 id="installation" class={headingClass}>Installation</h2>
    <p class="mb-4 text-clay-default text-sm leading-relaxed">
      Pull {component.name} from the barrel for everyday use, or the granular path when you want a
      tighter bundle.
    </p>
    <CodeSource code={barrelImport} lang="tsx" filename="Barrel" client:load />
    <CodeSource code={granularImport} lang="tsx" filename="Granular" client:load />
  </section>

  {
    heroDemo && (
      <section class="mb-14">
        <h2 id="usage" class={headingClass}>
          Usage
        </h2>
        <p class="mb-4 text-clay-default text-sm leading-relaxed">A minimal example to copy.</p>
        <CodeSource code={heroDemo.code} lang="tsx" filename={`${component.name}.tsx`} client:load />
      </section>
    )
  }

  {
    moreDemos.length > 0 && (
      <section class="mb-14">
        <h2 id="examples" class={`${headingClass} mb-6`}>
          Examples
        </h2>
        {moreDemos.map((demo) => (
          <section class="mb-10">
            <h3 id={slugifyTitle(demo.title)} class={subHeadingClass}>
              {demo.title}
            </h3>
            {demo.description && (
              <p class="mb-4 text-clay-default text-sm leading-relaxed">{demo.description}</p>
            )}
            <ComponentExample code={demo.code}>
              <DemoRenderer slug={component.slug} demoName={demo.name} client:only="react" />
            </ComponentExample>
          </section>
        ))}
      </section>
    )
  }

  {
    component.accessibility && component.accessibility.length > 0 && (
      <section class="mb-14">
        <h2 id="accessibility" class={headingClass}>
          Accessibility
        </h2>
        <ul class="space-y-2 text-clay-default text-sm leading-relaxed">
          {component.accessibility.map((item) => (
            <li class="flex gap-2">
              <span aria-hidden="true" class="text-clay-subtle">
                ·
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    component.tokens && component.tokens.length > 0 && (
      <section class="mb-14">
        <h2 id="tokens" class={headingClass}>
          Tokens
        </h2>
        <p class="mb-3 text-clay-default text-sm leading-relaxed">
          {component.name} reads the following theme tokens:
        </p>
        <div class="flex flex-wrap gap-1.5">
          {component.tokens.map((token) => (
            <code class="rounded border border-clay-hairline bg-clay-base px-2 py-0.5 font-mono text-clay-default text-xs">
              {token}
            </code>
          ))}
        </div>
      </section>
    )
  }

  <section class="mb-14">
    <h2 id="api-reference" class={headingClass}>API reference</h2>
    <p class="text-clay-default text-sm leading-relaxed">
      {component.name} is a thin React wrapper. Native HTML attributes pass through; for the full
      type signature, see the
      <a
        href={githubBase}
        rel="noopener noreferrer"
        class="text-clay-link underline-offset-2 hover:underline"
      >
        component source on GitHub
      </a>.
    </p>
  </section>

  <nav class="not-prose mt-16 flex items-stretch gap-4 border-clay-hairline border-t pt-6">
    {
      previous ? (
        <a
          href={`/components/${previous.slug}`}
          class="group flex flex-1 flex-col items-start gap-1 rounded-lg border border-clay-hairline bg-clay-elevated px-4 py-3 transition-colors hover:bg-clay-control"
        >
          <span class="font-mono text-[0.625rem] text-clay-subtle uppercase tracking-wider">
            ← Previous
          </span>
          <span class="font-medium text-clay-strong text-sm">{previous.name}</span>
        </a>
      ) : (
        <span class="flex-1" />
      )
    }
    {
      next ? (
        <a
          href={`/components/${next.slug}`}
          class="group flex flex-1 flex-col items-end gap-1 rounded-lg border border-clay-hairline bg-clay-elevated px-4 py-3 transition-colors hover:bg-clay-control"
        >
          <span class="font-mono text-[0.625rem] text-clay-subtle uppercase tracking-wider">
            Next →
          </span>
          <span class="font-medium text-clay-strong text-sm">{next.name}</span>
        </a>
      ) : (
        <span class="flex-1" />
      )
    }
  </nav>
</MdxDocLayout>
