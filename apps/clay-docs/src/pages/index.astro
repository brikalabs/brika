---
import { ButtonPrimaryDemo } from '~/components/demos/button.tsx';
import MainLayout from '~/layouts/MainLayout.astro';
---

<MainLayout
  title="Clay — Brika's React component library"
  description="Pressable raw material for every Brika surface. Tokens, components, themes — one package."
>
  <section class="py-12 text-center">
    <h1 class="font-bold text-5xl tracking-tight">Clay</h1>
    <p class="mx-auto mt-4 max-w-xl text-slate-600 text-lg dark:text-slate-400">
      Brika's React component library and first-party themes. Built on Radix,
      CVA, and Tailwind v4.
    </p>
    <div class="mt-8 flex items-center justify-center gap-4">
      <a
        href="/components/button"
        class="rounded-md bg-slate-900 px-4 py-2 font-medium text-sm text-white hover:bg-slate-800 dark:bg-slate-100 dark:text-slate-900 dark:hover:bg-white"
      >
        Browse components
      </a>
      <a
        href="https://github.com/brikalabs/brika"
        class="rounded-md border border-slate-300 px-4 py-2 font-medium text-sm hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800"
        rel="noreferrer"
      >
        GitHub
      </a>
    </div>
  </section>

  <section class="py-12">
    <h2 class="mb-6 font-semibold text-xl tracking-tight">Install</h2>
    <pre class="overflow-x-auto rounded-lg bg-slate-900 p-4 text-slate-100 text-sm"><code>bun add @brika/clay</code></pre>
  </section>

  <section class="py-12">
    <h2 class="mb-6 font-semibold text-xl tracking-tight">A taste</h2>
    <div class="flex items-center justify-center rounded-lg border border-slate-200 bg-white p-10 dark:border-slate-800 dark:bg-slate-900">
      <ButtonPrimaryDemo client:load />
    </div>
  </section>
</MainLayout>
