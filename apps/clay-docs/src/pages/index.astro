---
import { HomeGrid } from '~/components/demos/HomeGrid.tsx';
import { PackageManager } from '~/components/docs/PackageManager.tsx';
import MainLayout from '~/layouts/MainLayout.astro';
---

<MainLayout
  title="Clay — Brika's React component library"
  description="Pressable raw material for every Brika surface. Tokens, components, themes — one package."
>
  <section class="border-clay-hairline border-b px-6 py-20 md:px-12">
    <div class="mx-auto max-w-3xl">
      <p class="mb-4 font-mono text-clay-subtle text-xs uppercase tracking-wider">
        Design system · v0
      </p>
      <h1 class="font-semibold text-4xl text-clay-strong tracking-tighter md:text-5xl">
        Clay — the raw material bricks are pressed from.
      </h1>
      <p class="mt-6 max-w-xl text-clay-subtle text-lg leading-relaxed">
        Brika's React component library. Built on Radix, CVA, and Tailwind v4.
        Tokenised, themeable, and consumable by any Brika app without pulling in
        hub or feature code.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="/components/button"
          class="inline-flex h-9 items-center rounded border border-clay-hairline px-4 font-medium text-sm transition-colors"
          style="background-color: var(--text-color-clay-strong); color: var(--color-clay-canvas);"
        >
          Browse components
        </a>
        <a
          href="/installation"
          class="inline-flex h-9 items-center rounded border border-clay-hairline bg-clay-elevated px-4 font-medium text-clay-default text-sm transition-colors hover:bg-clay-control"
        >
          Installation
        </a>
      </div>
      <div class="mt-6 max-w-xl">
        <PackageManager package="@brika/clay" client:load />
      </div>
    </div>
  </section>

  <section>
    <HomeGrid client:only="react" />
  </section>

  <section class="border-clay-hairline border-t px-6 py-12 md:px-12">
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <h3 class="mb-2 font-medium font-mono text-clay-subtle text-xs uppercase tracking-wider">
          Tokenised
        </h3>
        <p class="text-clay-default text-sm">
          Every colour, radius, and spacing value routes through CSS custom
          properties. Swap the token layer, swap the look.
        </p>
      </div>
      <div>
        <h3 class="mb-2 font-medium font-mono text-clay-subtle text-xs uppercase tracking-wider">
          Accessible
        </h3>
        <p class="text-clay-default text-sm">
          Radix primitives under the hood — focus rings, ARIA attributes, and
          keyboard navigation are first-class.
        </p>
      </div>
      <div>
        <h3 class="mb-2 font-medium font-mono text-clay-subtle text-xs uppercase tracking-wider">
          Portable
        </h3>
        <p class="text-clay-default text-sm">
          Zero coupling to Brika's hub or auth. A docs site, a plugin UI, or a
          fresh SPA can all consume it cleanly.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
