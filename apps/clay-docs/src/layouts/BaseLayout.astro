---
import '~/styles/global.css';

interface Props {
  readonly title: string;
  readonly description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <script is:inline>
      (() => {
        // Set both `data-mode` (light/dark) and `data-theme` (preset id)
        // synchronously, before the first paint, AND lazy-load only the
        // chosen theme's CSS file. The link is inserted in <head> while
        // the parser is still here, so the browser blocks paint until
        // the small (~4 KB) per-theme stylesheet loads — no flash, and
        // we don't pay for the 15 themes the user never picks.
        try {
          const root = document.documentElement;

          const MODE_KEY = 'clay-mode';
          const storedMode = localStorage.getItem(MODE_KEY);
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const mode =
            storedMode === 'light' || storedMode === 'dark'
              ? storedMode
              : prefersDark
                ? 'dark'
                : 'light';
          root.dataset.mode = mode;

          const THEME_KEY = 'clay-theme';
          const storedTheme = localStorage.getItem(THEME_KEY);
          // Whitelist preset ids so a corrupt localStorage value can't
          // cause us to fetch an arbitrary URL.
          const KNOWN = new Set([
            'default', 'ocean', 'forest', 'sunset', 'lavender', 'ruby',
            'nord', 'solarized', 'candy', 'dracula', 'mono',
            'brutalist', 'editorial', 'terminal', 'skeuomorph', 'glass',
            'comic',
          ]);
          if (storedTheme && KNOWN.has(storedTheme)) {
            root.dataset.theme = storedTheme;
            if (storedTheme !== 'default') {
              const link = document.createElement('link');
              link.rel = 'stylesheet';
              link.href = '/_clay-themes/' + storedTheme + '.css';
              link.id = 'clay-theme-link';
              link.dataset.themeId = storedTheme;
              document.head.appendChild(link);
            }
          }
        } catch {
          /* localStorage / matchMedia unavailable — let CSS defaults render. */
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
