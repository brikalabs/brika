---
import BaseLayout from './BaseLayout.astro';

interface Props {
  readonly title: string;
  readonly description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="border-b border-slate-200 dark:border-slate-800">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="font-semibold text-lg tracking-tight">Clay</a>
      <nav class="flex gap-6 text-sm">
        <a href="/components/button" class="hover:underline">Components</a>
        <a
          href="https://github.com/brikalabs/brika"
          class="hover:underline"
          rel="noreferrer"
        >
          GitHub
        </a>
      </nav>
    </div>
  </header>
  <main class="mx-auto max-w-6xl px-6 py-10">
    <slot />
  </main>
  <footer class="mt-24 border-t border-slate-200 py-8 text-center text-slate-500 text-sm dark:border-slate-800">
    Built with Brika · Clay is pressable raw material.
  </footer>
</BaseLayout>
