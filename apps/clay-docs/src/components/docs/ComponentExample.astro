---
import CodeSource from './CodeSource.astro';

/**
 * Renders a live demo above a syntax-highlighted code block in a single
 * unified card: rounded outer border, preview on top, code flush below
 * separated only by a hairline. No nested rounding, no inner panels.
 */

interface Props {
  readonly code: string;
  readonly lang?: 'tsx' | 'ts' | 'jsx' | 'js' | 'bash' | 'css' | 'html';
}

const { code, lang = 'tsx' } = Astro.props;
---

<div class="component-example not-prose my-6 overflow-hidden rounded-lg border border-clay-hairline bg-clay-elevated">
  <div class="component-example-preview relative flex min-h-50 items-center justify-center px-6 py-10">
    <slot />
  </div>
  <div class="border-clay-hairline border-t">
    <CodeSource code={code} lang={lang} variant="compact" />
  </div>
</div>

<style is:global>
  .component-example-preview {
    background-image: radial-gradient(
      circle at 1px 1px,
      var(--color-clay-hairline) 1px,
      transparent 0
    );
    background-size: 18px 18px;
  }
</style>
