---
import { CodeSource } from './CodeSource.tsx';

/**
 * Renders a live demo above a syntax-highlighted code block. Delegates to
 * `<CodeSource variant="compact">` (which wraps Clay's CodeBlock primitive)
 * so docs and runtime markdown render identically.
 */

interface Props {
  readonly code: string;
  readonly lang?: 'tsx' | 'ts' | 'jsx' | 'js' | 'bash' | 'css' | 'html';
}

const { code, lang = 'tsx' } = Astro.props;
---

<div class="not-prose my-6 overflow-hidden rounded-lg border border-clay-hairline">
  <div class="flex min-h-45 items-center justify-center bg-clay-elevated p-8">
    <slot />
  </div>
  <div class="border-clay-hairline border-t bg-clay-base">
    <CodeSource code={code} lang={lang} variant="compact" client:load />
  </div>
</div>
