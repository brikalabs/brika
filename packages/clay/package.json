{
  "name": "@brika/clay",
  "version": "0.0.0",
  "description": "Clay — Brika's React component library and first-party themes",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/clay#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/clay"
  },
  "keywords": ["brika", "clay", "react", "components", "design-system", "tailwind"],
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*/index.ts",
    "./primitives": "./src/primitives/index.ts",
    "./primitives/*": "./src/primitives/*.ts",
    "./styles": "./src/styles/clay.css",
    "./styles/themes-static.css": "./src/styles/themes-static.css",
    "./tailwind-preset": "./src/tailwind-preset.ts",
    "./themes": "./src/themes/index.ts",
    "./tokens": "./src/tokens/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "build:tokens": "bun run scripts/build-tokens.ts",
    "build:themes": "bun run scripts/build-themes.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "recharts": "3.7.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
