{
  "name": "@brika/clay",
  "version": "0.1.0",
  "description": "Clay — Brika's React component library, token system, and first-party themes",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://clay.brika.dev",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/clay"
  },
  "keywords": [
    "brika",
    "clay",
    "react",
    "components",
    "design-system",
    "tailwind",
    "tailwindcss",
    "themes"
  ],
  "sideEffects": [
    "**/*.css",
    "**/components/*/tokens.ts",
    "**/components/*/tokens.js",
    "**/tokens/components.ts",
    "**/tokens/components.js",
    "**/tokens/orphan-components.ts",
    "**/tokens/orphan-components.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./primitives/*": {
      "types": "./dist/primitives/*.d.ts",
      "import": "./dist/primitives/*.js"
    },
    "./styles": "./dist/styles/clay.css",
    "./styles/*": "./dist/styles/*.css",
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "recharts": "^3.7.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5"
  }
}
