{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.brika.dev/0.1.0/package.json",
  "title": "BRIKA Plugin package.json",
  "description": "Schema for BRIKA plugin package.json files",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/package.json"
    }
  ],
  "required": ["name", "version", "engines"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Plugin package name (used as plugin ID)"
    },
    "version": {
      "type": "string",
      "description": "Plugin version (semver)"
    },
    "description": {
      "type": "string",
      "description": "Short description of the plugin"
    },
    "author": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          }
        }
      ],
      "description": "Plugin author"
    },
    "repository": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "directory": {
              "type": "string"
            }
          }
        }
      ],
      "description": "Repository URL (e.g., GitHub)"
    },
    "icon": {
      "type": "string",
      "description": "Path to plugin icon (PNG, relative to package root)",
      "examples": ["./icon.png", "./assets/icon.png"]
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Keywords for plugin discovery"
    },
    "license": {
      "type": "string",
      "description": "Plugin license (e.g., MIT, Apache-2.0)"
    },
    "engines": {
      "type": "object",
      "description": "Engine compatibility requirements",
      "required": ["brika"],
      "properties": {
        "brika": {
          "type": "string",
          "description": "Required BRIKA hub version (semver range, e.g., ^0.1.0)",
          "examples": ["^0.1.0", "~0.1.0", ">=0.1.0"]
        }
      }
    },
    "tools": {
      "type": "array",
      "description": "Tools provided by this plugin",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Tool identifier (local to plugin)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the tool"
          },
          "icon": {
            "type": "string",
            "description": "Lucide icon name"
          },
          "color": {
            "type": "string",
            "description": "Hex color for the tool"
          }
        }
      }
    },
    "blocks": {
      "type": "array",
      "description": "Workflow blocks provided by this plugin",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Block identifier (local to plugin)"
          },
          "name": {
            "type": "string",
            "description": "Display name for the block"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the block"
          },
          "category": {
            "type": "string",
            "enum": ["trigger", "flow", "action", "transform"],
            "description": "Block category"
          },
          "icon": {
            "type": "string",
            "description": "Lucide icon name"
          },
          "color": {
            "type": "string",
            "description": "Hex color for the block"
          }
        }
      }
    }
  }
}
