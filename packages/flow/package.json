{
  "name": "@brika/flow",
  "version": "0.4.0",
  "description": "Reactive stream library for BRIKA workflows",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/flow#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/flow"
  },
  "keywords": ["brika", "reactive", "streams", "flow"],
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*_test-utils.ts",
    "!src/**/tsconfig.json",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "test": "bun test --parallel",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run tsc"
  },
  "dependencies": {
    "@brika/serializable": "workspace:*"
  },
  "devDependencies": {
    "@brika/testing": "workspace:*"
  }
}
