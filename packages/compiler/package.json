{
  "name": "@brika/compiler",
  "version": "0.4.0",
  "description": "Brika plugin compile gate: accept/reject a plugin and report its capabilities + actions, on Bun or in a V8 isolate / Cloudflare Worker.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "packages/compiler"
  },
  "keywords": ["brika", "compiler", "bundler", "cloudflare-workers", "plugin"],
  "exports": {
    ".": "./src/index.ts",
    "./bun": {
      "types": "./dist/bun/index.d.ts",
      "default": "./dist/bun/index.js"
    },
    "./v8": {
      "types": "./dist/v8/index.d.ts",
      "default": "./dist/v8/index.js"
    }
  },
  "files": ["dist", "src", "!src/**/*.test.ts", "!src/**/*.integration.test.ts"],
  "scripts": {
    "build": "bun run build.ts",
    "nightly": "bun run nightly.ts",
    "prepack": "bun run build.ts --dts",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:cf": "bun run build && bun run cf-test/run.ts",
    "verify:parity": "bun run verify-parity.ts"
  },
  "dependencies": {
    "@rollup/browser": "^3.30.0",
    "sucrase": "^3.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@brika/sdk": "workspace:*",
    "@types/bun": "^1.3.14",
    "dts-bundle-generator": "9",
    "wrangler": "^4.105.0"
  }
}
