{
  "name": "@brika/compiler",
  "version": "0.4.0",
  "type": "module",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "packages/compiler"
  },
  "keywords": ["brika", "compiler", "build", "plugin"],
  "exports": {
    ".": "./src/index.ts",
    "./bun": "./dist/bun/index.js",
    "./v8": "./dist/v8/index.js"
  },
  "files": ["dist", "src", "!src/**/*.test.ts", "!src/**/*.integration.test.ts"],
  "scripts": {
    "build": "bun run build.ts",
    "nightly": "bun run nightly.ts",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:cf": "bun run build && bun run cf-test/run.ts",
    "verify:parity": "bun run verify-parity.ts"
  },
  "dependencies": {
    "@rollup/browser": "^3.30.0",
    "sucrase": "^3.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@brika/sdk": "workspace:*",
    "@types/bun": "^1.3.14",
    "wrangler": "^4.105.0"
  }
}
