{
  "name": "@brika/sdk",
  "version": "0.4.0",
  "description": "SDK for building BRIKA plugins and workflow blocks",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/sdk"
  },
  "keywords": ["brika", "sdk", "plugins", "workflow", "home-automation"],
  "engines": {
    "bun": ">=1.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./brick-views": "./src/brick-views.ts",
    "./block-views": "./src/block-views.ts",
    "./brick": "./src/brick.ts",
    "./schema": "./src/blocks/schema.ts",
    "./sparks": "./src/sparks.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./storage": "./src/storage.ts",
    "./testing": "./src/testing.ts",
    "./ui-kit": "./src/ui-kit/index.ts",
    "./ui-kit/icons": "./src/ui-kit/icons.ts",
    "./ui-kit/hooks": "./src/ui-kit/hooks.ts",
    "./bridge": "./src/bridge.ts",
    "./ctx": "./src/ctx.ts",
    "./grants": "./src/grants/index.ts",
    "./grants/fs-runtime": "./src/grants/fs-runtime.ts",
    "./actions": "./src/actions.ts",
    "./collect": "./src/internal/collect.ts",
    "./exec-context": "./src/exec-context.ts",
    "./verify-plugin": "./src/verify-plugin.ts",
    "./cli": "./src/cli/index.ts",
    "./tsconfig.plugin.json": "./tsconfig.plugin.json"
  },
  "bin": {
    "brika": "./dist/bin/brika.js"
  },
  "files": [
    "src",
    "dist/bin",
    "tsconfig.plugin.json",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*_test-utils.ts"
  ],
  "scripts": {
    "test": "bun test --parallel",
    "typecheck": "tsgo --noEmit",
    "build:bin": "bun build-bin.ts",
    "smoke:bin": "bun smoke-bin.ts",
    "prepare": "bun run build:bin"
  },
  "dependencies": {
    "@brika/errors": "workspace:*",
    "@brika/grants": "workspace:*",
    "@brika/ipc": "workspace:*",
    "zod": "^4.3.4"
  },
  "peerDependencies": {
    "zod": "^4.0.0",
    "lucide-react": "^1.17.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@brika/cli": "workspace:*",
    "@brika/compiler": "workspace:*",
    "@brika/flow": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/serializable": "workspace:*",
    "@brika/testing": "workspace:*",
    "@brika/ui-kit": "workspace:*",
    "@types/bun": "^1.3.5",
    "picocolors": "^1.1.1"
  }
}
