{
  "name": "@brika/sdk",
  "version": "0.3.0",
  "description": "SDK for building BRIKA plugins and workflow blocks",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/maxscharwath/brika/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/maxscharwath/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxscharwath/brika.git",
    "directory": "packages/sdk"
  },
  "keywords": ["brika", "sdk", "plugins", "workflow", "home-automation"],
  "exports": {
    ".": "./src/index.ts",
    "./bricks": "./src/bricks.ts",
    "./sparks": "./src/sparks.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./storage": "./src/storage.ts",
    "./testing": "./src/testing.ts",
    "./ui-kit": "./src/ui-kit/index.ts",
    "./ui-kit/icons": "./src/ui-kit/icons.ts",
    "./ui-kit/hooks": "./src/ui-kit/hooks.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts"
  },
  "bin": {
    "brika-verify-plugin": "./src/verify.ts"
  },
  "files": ["src"],
  "scripts": {
    "tsc": "bunx --biome tsc --noEmit",
    "prepublishOnly": "bun run tsc"
  },
  "dependencies": {
    "@brika/flow": "workspace:*",
    "@brika/ipc": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/serializable": "workspace:*",
    "@brika/ui-kit": "workspace:*",
    "picocolors": "^1.1.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5"
  }
}
