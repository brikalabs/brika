{
  "name": "@brika/sdk",
  "version": "0.3.0",
  "description": "SDK for building BRIKA plugins and workflow blocks",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/maxscharwath/brika/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/maxscharwath/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxscharwath/brika.git",
    "directory": "packages/sdk"
  },
  "keywords": ["brika", "sdk", "plugins", "workflow", "home-automation"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bricks": {
      "types": "./dist/bricks.d.ts",
      "default": "./dist/bricks.js"
    },
    "./sparks": {
      "types": "./dist/sparks.d.ts",
      "default": "./dist/sparks.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle.d.ts",
      "default": "./dist/lifecycle.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./ui-kit": {
      "types": "./dist/ui-kit/index.d.ts",
      "default": "./dist/ui-kit/index.js"
    },
    "./ui-kit/icons": {
      "types": "./dist/ui-kit/icons.d.ts",
      "default": "./dist/ui-kit/icons.js"
    },
    "./ui-kit/hooks": {
      "types": "./dist/ui-kit/hooks.d.ts",
      "default": "./dist/ui-kit/hooks.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "default": "./dist/jsx-dev-runtime.js"
    },
    "./tsconfig.plugin.json": "./tsconfig.plugin.json"
  },
  "bin": {
    "brika-verify-plugin": "./dist/verify.js"
  },
  "files": ["dist", "tsconfig.plugin.json"],
  "scripts": {
    "build": "bun run build.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.4"
  },
  "peerDependencies": {
    "zod": "^4.0.0",
    "lucide-react": ">=0.400.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@brika/flow": "workspace:*",
    "@brika/ipc": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/serializable": "workspace:*",
    "@brika/ui-kit": "workspace:*",
    "@types/bun": "^1.3.5",
    "picocolors": "^1.1.1"
  }
}
