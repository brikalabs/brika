{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://elia.dev/schemas/plugin.json",
  "title": "ELIA Plugin package.json",
  "description": "Schema for ELIA plugin package.json files",
  "type": "object",
  "allOf": [
    { "$ref": "https://json.schemastore.org/package.json" }
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Plugin package name (used as plugin ID)"
    },
    "version": {
      "type": "string",
      "description": "Plugin version (semver)"
    },
    "description": {
      "type": "string",
      "description": "Short description of the plugin"
    },
    "author": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "url": { "type": "string" }
          }
        }
      ],
      "description": "Plugin author"
    },
    "repository": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "url": { "type": "string" }
          }
        }
      ],
      "description": "Repository URL (e.g., GitHub)"
    },
    "icon": {
      "type": "string",
      "description": "Path to plugin icon (PNG, relative to package root)",
      "examples": ["./icon.png", "./assets/icon.png"]
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Keywords for plugin discovery"
    },
    "license": {
      "type": "string",
      "description": "Plugin license (e.g., MIT, Apache-2.0)"
    }
  }
}

