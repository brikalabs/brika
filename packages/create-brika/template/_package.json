{
  "$schema": "https://schema.brika.dev/plugin.schema.json",
  "name": "{{packageName}}",
  "version": "0.1.0",
  "description": "{{description}}",
  "author": "{{author}}",
  "keywords": [
    "brika",
    "plugin",
    "{{name}}"
  ],
  "engines": {
    "brika": "^{{sdkVersion}}"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "link": "bun link",
    "tsc": "bunx --bun tsc --noEmit"
  },
  "blocks": [
    {
      "id": "{{blockId}}",
      "name": "{{blockNamePascal}}",
      "description": "{{description}}",
      "category": "{{category}}",
      "icon": "box",
      "color": "#3b82f6"
    }
  ],
  "dependencies": {
    "@brika/sdk": "^{{sdkVersion}}"
  },
  "devDependencies": {
    "bun-types": "^1.3.5"
  }
}
