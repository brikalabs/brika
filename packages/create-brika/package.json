{
  "name": "create-brika",
  "version": "0.4.0",
  "description": "Create a new BRIKA plugin with a single command",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/create-brika"
  },
  "keywords": ["brika", "plugin", "scaffold", "cli", "create"],
  "bin": {
    "create-brika": "./dist/index.js"
  },
  "exports": {
    "./run": "./src/run.ts"
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*_test-utils.ts",
    "!src/**/tsconfig.json",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@brika/cli": "workspace:*",
    "@types/bun": "^1.3.5",
    "picocolors": "^1.1.1"
  }
}
