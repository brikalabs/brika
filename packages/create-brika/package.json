{
  "name": "create-brika",
  "knip": { "entry": ["src/**/*.ts"] },
  "version": "0.4.0",
  "description": "Create a new BRIKA plugin with a single command",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/create-brika"
  },
  "keywords": ["brika", "plugin", "scaffold", "cli", "create"],
  "bin": {
    "create-brika": "./dist/index.js"
  },
  "exports": {
    "./run": {
      "types": "./src/run.ts",
      "default": "./dist/run.js"
    }
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!src/**/*.{test,spec}.{ts,tsx}",
    "!src/**/{*_test-utils.ts,tsconfig.json,*.bench.ts,__benchmarks__/**}",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "smoke:bin": "BRIKA_BIN_SMOKE=1 bun test smoke-bin.e2e.integration.test.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@brika/cli": "workspace:*",
    "@brika/workspace-tools": "workspace:*",
    "@types/bun": "^1.3.5",
    "picocolors": "^1.1.1",
    "zod": "^4.3.4"
  }
}
