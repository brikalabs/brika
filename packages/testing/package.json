{
  "name": "@brika/testing",
  "private": true,
  "version": "0.4.0",
  "description": "Bun test helpers (mocks, fixtures) bundled into @brika/sdk/testing; not published standalone",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/testing"
  },
  "keywords": ["brika", "testing", "bun", "mocks"],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!src/**/*.{test,spec}.{ts,tsx}",
    "!src/**/{*_test-utils.ts,tsconfig.json,*.bench.ts,__benchmarks__/**}",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "test": "bun test"
  },
  "peerDependencies": {
    "bun-types": "^1.0.0"
  }
}
