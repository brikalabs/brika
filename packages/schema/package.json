{
  "name": "@brika/schema",
  "version": "0.1.1",
  "description": "Unified schemas for BRIKA plugins and configuration",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxscharwath/brika.git",
    "directory": "packages/schema"
  },
  "files": ["dist", "src"],
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./plugin.json": "./dist/plugin.schema.json"
  },
  "scripts": {
    "build": "bun run src/generate-schemas.ts",
    "dev": "bun run src/generate-schemas.ts --watch",
    "prepublishOnly": "bun run build",
    "release": "bun run scripts/publish.ts"
  },
  "dependencies": {
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "bun-types": "^1.3.5"
  }
}
