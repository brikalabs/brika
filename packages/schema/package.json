{
  "name": "@brika/schema",
  "version": "0.4.0",
  "description": "Unified schemas for BRIKA plugins and configuration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/schema"
  },
  "keywords": ["brika", "schema", "zod", "validation"],
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*_test-utils.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./plugin.json": "./dist/plugin.schema.json"
  },
  "scripts": {
    "build": "bun run src/generate-schemas.ts",
    "dev": "bun run src/generate-schemas.ts --watch",
    "prepublishOnly": "bun run build",
    "release": "bun run scripts/publish.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "bun-types": "^1.3.5"
  }
}
