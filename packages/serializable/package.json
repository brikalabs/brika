{
  "name": "@brika/serializable",
  "version": "0.4.0",
  "private": true,
  "description": "Serialization utilities for BRIKA with Zod schema support",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/serializable#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/serializable"
  },
  "keywords": ["brika", "serialization", "zod", "schema"],
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!src/**/*.{test,spec}.{ts,tsx}",
    "!src/**/{*_test-utils.ts,tsconfig.json,*.bench.ts,__benchmarks__/**}",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "bun run tsc"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
