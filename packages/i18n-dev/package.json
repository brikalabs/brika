{
  "name": "@brika/i18n-devtools",
  "version": "0.4.0",
  "type": "module",
  "license": "MIT",
  "description": "i18n developer tools: Vite plugin + browser overlay for translation key validation, coverage tracking, and in-app editing. Works with any React + i18next project.",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/i18n-dev#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/brika.git",
    "directory": "packages/i18n-dev"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translations",
    "react",
    "i18next",
    "vite-plugin",
    "devtools",
    "overlay",
    "typescript",
    "bun"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts",
    "./overlay": "./src/overlay/index.tsx"
  },
  "bin": {
    "brika-i18n": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*_test-utils.ts"
  ],
  "sideEffects": ["./src/overlay/index.tsx", "./src/entry.ts", "./src/hmr-events.ts"],
  "scripts": {
    "test": "bun test --parallel",
    "typecheck": "tsgo --noEmit",
    "check": "bun src/check.ts",
    "generate-types": "bun src/generate-types.ts"
  },
  "peerDependencies": {
    "@brika/i18n": ">=0.3.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": ">=4.0.0",
    "vite": "^8.0.16",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@brika/i18n": "workspace:*",
    "@brika/testing": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.1.0",
    "vite": "^8.0.16",
    "zod": "^4.3.4"
  }
}
