{
  "name": "@brika/grants",
  "version": "0.4.0",
  "description": "Typed capability/grant registry — the single primitive every plugin uses to call the hub",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/grants"
  },
  "keywords": ["brika", "grants", "capabilities", "sandbox", "ocap"],
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*_test-utils.ts",
    "!src/**/tsconfig.json",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@brika/errors": "workspace:*",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@brika/testing": "workspace:*",
    "@types/bun": "^1.3.5"
  }
}
