  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/i18n"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translations",
    "react",
    "i18next",
    "vite",
    "bun",
    "suspense",
    "typescript"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./node": "./src/node/index.ts",
    "./react": "./src/react/index.ts",
    "./registry": "./src/registry.ts"
  },
  "files": ["src", "README.md", "CHANGELOG.md", "LICENSE"],
