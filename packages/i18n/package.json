    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "i18next-browser-languagedetector": {
      "optional": true
    }
  },
  "devDependencies": {
    "@brika/testing": "workspace:*",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "zod": "^4.3.4"
  }
