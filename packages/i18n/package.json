{
  "name": "@brika/i18n",
  "version": "0.3.1",
  "description": "Generic i18n runtime: translation registry, React hooks, Node loaders, and SSE-driven live reload. Works with any React + Vite + Bun project.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/i18n#readme",
  "bugs": {
