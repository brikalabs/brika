# Hub
ELIA_HOST=127.0.0.1
ELIA_PORT=4111
ELIA_HOME=.elia
ELIA_LOG_LEVEL=info
ELIA_LOG_COLOR=1

# Optional: preload plugins at boot (comma-separated refs)
# ELIA_PLUGINS=@elia/plugin-example-echo

# Optional: registry base URL for store browsing (npm registry-compatible)
# ELIA_REGISTRY_URL=https://registry.npmjs.org
