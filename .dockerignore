# Git
.git
.gitignore

# IDE and editor files
.cursor
.vscode
.idea
*.swp
*.swo

# Documentation
*.md
!README.md
docs/
PLAN-*.md

# Build outputs (will be generated in container)
**/dist/
**/build/
**/*.tsbuildinfo

# Development artifacts
.brika/
apps/hub/.brika/
**/*.log

# Test files
**/__tests__/
**/tests/
**/*.test.ts
**/*.spec.ts
coverage/

# Node modules are installed fresh in container
# But we keep the lockfile for reproducible builds
# node_modules/ is not ignored because we copy it from deps stage

# OS files
.DS_Store
Thumbs.db

# Environment files (secrets should be passed via env vars)
.env
.env.*
!.env.example

# Docker files (not needed inside container)
Dockerfile
docker-compose*.yml
.dockerignore

