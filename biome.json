{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": false
  },

  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "expand": "auto",
    "useEditorconfig": true,
    "includes": [
      "apps/**",
      "packages/**",
      "scripts/**",
      "*.json",
      "*.config.*",
      "!biome.json",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/build/**",
      "!**/coverage/**",
      "!**/logs/**",
      "!**/*.log",
      "!**/.env",
      "!**/.env.*",
      "!**/*.md",
      "!**/template/**"
    ]
  },

  "linter": {
    "enabled": true,
    "includes": [
      "apps/**/src/**/*.{ts,tsx,js,jsx,mts,cts}",
      "packages/**/src/**/*.{ts,tsx,js,jsx,mts,cts}",
      "scripts/**/*.{ts,tsx,js,jsx,mts,cts}",
      "apps/**/src/**/*.{html,vue,svelte,astro,mdx}",
      "packages/**/src/**/*.{html,vue,svelte,astro,mdx}",
      "!**/template/**"
    ],
    "rules": {
      "recommended": false,

      "complexity": {
        "noAdjacentSpacesInRegex": "error",
        "noBannedTypes": "error",
        "noExtraBooleanCast": "error",
        "noUselessCatch": "error",
        "noUselessEscapeInRegex": "error",
        "noUselessTypeConstraint": "error",
        "noUselessRename": "error",
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 25 }
        }
      },

      "correctness": {
        "noConstAssign": "error",
        "noConstantCondition": "error",
        "noEmptyCharacterClassInRegex": "error",
        "noEmptyPattern": "error",
        "noGlobalObjectCalls": "error",
        "noInnerDeclarations": "error",
        "noInvalidConstructorSuper": "error",
        "noNonoctalDecimalEscape": "error",
        "noPrecisionLoss": "error",
        "noSelfAssign": "error",
        "noSetterReturn": "error",
        "noSwitchDeclarations": "error",
        "noUndeclaredVariables": "error",
        "noUnreachable": "error",
        "noUnreachableSuper": "error",
        "noUnsafeFinally": "error",
        "noUnsafeOptionalChaining": "error",
        "noUnusedLabels": "error",
        "noUnusedVariables": "error",
        "useIsNan": "error",
        "useValidForDirection": "error",
        "useValidTypeof": "error",
        "useYield": "error"
      },

      "style": {
        "noNamespace": "error",
        "noExportedImports": "error",
        "noNonNullAssertion": "error",
        "useArrayLiterals": "error",
        "useAsConstAssertion": "error",
        "useTemplate": "error",
        "noYodaExpression": "error",
        "useNodejsImportProtocol": "error",
        "noUselessElse": "error",
        "noNestedTernary": "error",
        "useBlockStatements": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "zod": {
                "importNames": ["nativeEnum"],
                "message": "The 'z.nativeEnum' method is deprecated. Use 'z.enum(Object.values(MyEnum))' or 'z.enum([...])' instead."
              }
            }
          }
        }
      },

      "suspicious": {
        "noAsyncPromiseExecutor": "error",
        "noCatchAssign": "error",
        "noClassAssign": "error",
        "noCompareNegZero": "error",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error", "info", "log"]
          }
        },
        "noControlCharactersInRegex": "error",
        "noDebugger": "error",
        "noDuplicateCase": "error",
        "noDuplicateClassMembers": "error",
        "noDuplicateElseIf": "error",
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noEmptyBlockStatements": "error",
        "noExplicitAny": "error",
        "noExtraNonNullAssertion": "error",
        "noFallthroughSwitchClause": "error",
        "noFunctionAssign": "error",
        "noGlobalAssign": "error",
        "noImportAssign": "error",
        "noIrregularWhitespace": "error",
        "noMisleadingCharacterClass": "error",
        "noMisleadingInstantiator": "error",
        "noNonNullAssertedOptionalChain": "error",
        "noPrototypeBuiltins": "error",
        "noRedeclare": "error",
        "noShadowRestrictedNames": "error",
        "noSparseArray": "error",
        "noUnsafeDeclarationMerging": "error",
        "noUnsafeNegation": "error",
        "noUselessRegexBackrefs": "error",
        "noWith": "error",
        "useAwait": "error",
        "useGetterReturn": "error",
        "noDeprecatedImports": "error",
        "noImportCycles": "error"
      },

      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "attributes": ["class", "className", "classList"],
            "functions": ["clsx", "cva", "tw", "tw.*", "cn"]
          }
        },
        "noUselessReturn": "error",
        "noEqualsToNull": "error"
      }
    }
  },

  "javascript": {
    "globals": ["Bun"],
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "quoteStyle": "single",
      "attributePosition": "auto",
      "bracketSpacing": true
    }
  },

  "html": {
    "formatter": {
      "indentScriptAndStyle": false,
      "selfCloseVoidElements": "always"
    }
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },

  "overrides": [
    {
      "includes": [
        "**/__tests__/**/*.{ts,tsx,mts,cts,js,jsx}",
        "**/testing/**/*.{ts,tsx,mts,cts,js,jsx}",
        "**/*.test.{ts,tsx,mts,cts,js,jsx}"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noBannedTypes": "off",
            "noExcessiveCognitiveComplexity": "off"
          },
          "correctness": {
            "useYield": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "noExplicitAny": "warn",
            "useAwait": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/ui-kit/src/jsx-runtime.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noBannedTypes": "off"
          },
          "style": {
            "noNamespace": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/ipc/src/client.ts", "packages/ipc/src/host.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUnsafeDeclarationMerging": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**/*.{ts,tsx,js,jsx,mts,cts}"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "correctness": {
            "noUndeclaredVariables": "off"
          }
        }
      },
      "javascript": {
        "globals": ["Bun"]
      }
    },
    {
      "includes": ["**/*.{ts,tsx,mts,cts,js,jsx}"],
      "linter": {
        "rules": {
          "complexity": {
            "noArguments": "error"
          },
          "correctness": {
            "noConstAssign": "off",
            "noGlobalObjectCalls": "off",
            "noInvalidConstructorSuper": "off",
            "noSetterReturn": "off",
            "noUndeclaredVariables": "off",
            "noUnreachable": "off",
            "noUnreachableSuper": "off"
          },
          "style": {
            "useConst": "error"
          },
          "suspicious": {
            "noDuplicateClassMembers": "off",
            "noDuplicateObjectKeys": "off",
            "noDuplicateParameters": "off",
            "noFunctionAssign": "off",
            "noImportAssign": "off",
            "noRedeclare": "off",
            "noUnsafeNegation": "off",
            "noVar": "error",
            "useGetterReturn": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/di/src/testing/types.ts", "packages/flow/src/flow.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ],

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
