.idea
node_modules
**/node_modules
**/dist
**/.cache

# Compiled from src/sw.ts by vite.config.ts (brikaSwPlugin) — generated artifact.
apps/signaling/public/sw.js
**/.DS_Store
.env
# Cloudflare Workers local secrets (loaded by miniflare). The committed
# `.dev.vars.example` is the template — real values stay out of git.
.dev.vars
**/.dev.vars
*.log
*.tsbuildinfo

# Docker volume mount folder (root-only — don't shadow nested `config/` dirs
# inside packages, e.g. packages/mortar/src/config/).
/config/

# BRIKA runtime data
.brika/
**/.brika/

# Runtime files `brika hub` writes when started from apps/console/ during
# smoke tests with no BRIKA_HOME set — pid file, local-trust token,
# instance id, and the data folders the hub bootstrap creates.
apps/console/brika.pid
apps/console/cli-token
apps/console/instance.id
apps/console/board-order.json
apps/console/boards/
apps/console/plugins/
apps/console/workflows/

# mortar exported logs (`s` keybind in the TUI dumps here)
.mortar-logs/
# mortar crash-recovery state (live child PIDs; reaped on next start)
.mortar-run.json

# Plugin persistent data
plugins/*/data/

# SonarQube
.scannerwork/
.sonar/
coverage/

# Astro
**/.astro/

# Next.js
.next/
next-env.d.ts

# OpenNext (Cloudflare)
.open-next/

# Biome reports
biome-report.json

# i18n: type artifacts generated by @brika/i18n-devtools. Live in the build
# cache; the augmentation merges via a `declare global { namespace BrikaI18n }`
# block so any `.d.ts` in the compilation graph picks it up regardless of
# location. Regenerated by `bun run i18n:types` and on every locale edit
# while `bun dev` is running.
**/node_modules/.cache/@brika/i18n-devtools/

# Bootstrap shell build output (apps/signaling-worker/bootstrap/build.ts emits
# here; gets uploaded by wrangler as the Worker's static asset binding).
apps/signaling-worker/public/

# Claude Code local state
.claude/

# archunit DSL tests create/destroy `.test-fixtures/` per-test (see
# packages/archunit/src/__tests__/dsl.test.ts). The dir should not be tracked.
**/__tests__/.test-fixtures/

# Snyk reads yarn.lock (it can't parse bun.lock). CI's snyk workflow
# generates it via 'bun install --yarn'; never commit it alongside bun.lock.
yarn.lock
