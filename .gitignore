.idea
node_modules
**/node_modules
**/dist
**/.cache
**/.DS_Store
.env
*.log
*.tsbuildinfo

# Docker volume mount folder (root-only — don't shadow nested `config/` dirs
# inside packages, e.g. packages/mortar/src/config/).
/config/

# BRIKA runtime data
.brika/
**/.brika/

# mortar exported logs (`s` keybind in the TUI dumps here)
.mortar-logs/

# Plugin persistent data
plugins/*/data/

# SonarQube
.scannerwork/
.sonar/
coverage/

# Astro
**/.astro/

# Next.js
.next/
next-env.d.ts

# OpenNext (Cloudflare)
.open-next/

# Biome reports
biome-report.json

# i18n: type artifacts generated by @brika/i18n-devtools (run `bun i18n:types`).
# Lives next to the source locale files so the namespace augmentation is in
# scope without a path alias.
**/locales/i18n-resources.d.ts
**/locales/i18n-namespaces.ts

# Claude Code local state
.claude/
