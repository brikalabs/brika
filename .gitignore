.idea
node_modules
**/node_modules
**/dist
**/.cache

# Compiled from src/sw.ts by vite.config.ts (brikaSwPlugin) — generated artifact.
apps/signaling/public/sw.js
**/.DS_Store
.env
# Cloudflare Workers local secrets (loaded by miniflare). The committed
# `.dev.vars.example` is the template — real values stay out of git.
.dev.vars
**/.dev.vars
*.log
*.tsbuildinfo

# Docker volume mount folder (root-only — don't shadow nested `config/` dirs
# inside packages, e.g. packages/mortar/src/config/).
/config/

# BRIKA runtime data
.brika/
**/.brika/

# Runtime files `brika hub` writes when started from apps/console/ during
# smoke tests with no BRIKA_HOME set — pid file, local-trust token,
# instance id, and the data folders the hub bootstrap creates.
apps/console/brika.pid
apps/console/cli-token
apps/console/instance.id
apps/console/board-order.json
apps/console/boards/
apps/console/plugins/
apps/console/workflows/

# mortar exported logs (`s` keybind in the TUI dumps here)
.mortar-logs/

# Plugin persistent data
plugins/*/data/

# SonarQube
.scannerwork/
.sonar/
coverage/

# Astro
**/.astro/

# Next.js
.next/
next-env.d.ts

# OpenNext (Cloudflare)
.open-next/

# Biome reports
biome-report.json

# i18n: type artifacts generated by @brika/i18n-devtools (run `bun i18n:types`).
# Lives next to the source locale files so the namespace augmentation is in
# scope without a path alias.
**/locales/i18n-resources.d.ts
**/locales/i18n-namespaces.ts

# Bootstrap shell build output (apps/signaling-worker/bootstrap/build.ts emits
# here; gets uploaded by wrangler as the Worker's static asset binding).
apps/signaling-worker/public/

# Claude Code local state
.claude/
